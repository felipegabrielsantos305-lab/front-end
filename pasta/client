:root {
    --primary-color: #4a90e2;
    --background-color: #f5f7fb;
    --card-background: #ffffff;
    --text-color: #333333;
    --danger-color: #e74c3c;
    --success-color: #2ecc71;
    --border-radius: 8px;
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

body {
    background-color: var(--background-color);
    color: var(--text-color);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 20px;
}

/* Telas de Autenticação */
.auth-container {
    background: var(--card-background);
    padding: 40px;
    border-radius: var(--border-radius);
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    width: 100%;
    max-width: 400px;
}

.auth-container h2 {
    margin-bottom: 24px;
    text-align: center;
}

.input-group {
    margin-bottom: 16px;
    display: flex;
    flex-direction: column;
}

.input-group label {
    margin-bottom: 6px;
    font-weight: 600;
    font-size: 14px;
}

.input-group input {
    padding: 10px;
    border: 1px solid #ccc;
    border-radius: var(--border-radius);
    font-size: 16px;
}

/* Botões */
button {
    cursor: pointer;
    padding: 10px 15px;
    border: none;
    border-radius: var(--border-radius);
    font-weight: bold;
    font-size: 16px;
    transition: background 0.2s;
}

.btn-main { background-color: var(--primary-color); color: white; width: 100%; }
.btn-main:hover { background-color: #357abd; }
.btn-secondary { background-color: #bdc3c7; color: white; }
.btn-danger { background-color: var(--danger-color); color: white; }

/* Dashboard de Tarefas */
.app-header {
    width: 100%;
    max-width: 600px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
}

.app-container {
    width: 100%;
    max-width: 600px;
