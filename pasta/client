// Configuração da URL base do back-end (ajuste a porta se o seu server rodar em outra)
const API_BASE_URL = 'http://localhost:3000';

// Elementos Globais Dom
const token = localStorage.getItem('token');

// Executa a lógica baseada na página atual
document.addEventListener('DOMContentLoaded', () => {
    // Validação de rota protegida: Se não houver token e estiver na index, joga pro login
    if (!token && window.location.pathname.endsWith('index.html')) {
        window.location.href = 'login.html';
        return;
    }

    // Inicializa os formulários dependendo da página carregada
    if (document.getElementById('loginForm')) initLogin();
    if (document.getElementById('registerForm')) initRegister();
    if (document.getElementById('taskList')) initTaskManagement();
});

// ==========================================
// MÓDULO DE AUTENTICAÇÃO (Login / Registro)
// ==========================================

function initLogin() {
    document.getElementById('loginForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = document.getElementById('loginEmail').value;
        const password = document.getElementById('loginPassword').value;

        try {
            const response = await fetch(`${API_BASE_URL}/login`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, password })
            });

            const data = await response.json();
            if (response.ok) {
                localStorage.setItem('token', data.token); // Salva o token JWT de autenticação
                window.location.href = 'index.html';
            } else {
                alert(data.error || 'Erro ao realizar login.');
            }
        } catch (error) {
            console.error('Erro na requisição:', error);
        }
    });
}

function initRegister() {
    document.getElementById('registerForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const name = document.getElementById('regName').value;
        const email = document.getElementById('regEmail').value;
        const password = document.getElementById('regPassword').value;

        try {
            const response = await fetch(`${API_BASE_URL}/register`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, email, password })
            });

            const data = await response.json();
            if (response.ok) {
                alert('Cadastro realizado com sucesso! Faça o login.');
                window.location.href = 'login.html';
            } else {
                alert(data.error || 'Erro ao cadastrar usuário.');
            }
        } catch (error) {
            console.error('Erro na requisição:', error);
        }
    });
}

// ==========================================
// MÓDULO DE GESTÃO DE TAREFAS (CRUD)
// ==========================================

function initTaskManagement() {
    // Botão de Logout
    document.getElementById('logoutBtn').addEventListener('click', () => {
        localStorage.removeItem('token');
        window.location.href = 'login.html';
    });

    const taskForm = document.getElementById('taskForm');
    const cancelEditBtn = document.getElementById('cancelEditBtn');

    // Carregar tarefas iniciais
    fetchTasks();

    // Submissão do formulário (Criação ou Edição)
    taskForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const taskId = document.getElementById('taskId').value;
        const title = document.getElementById('taskTitle').value;

        if (taskId) {
            // Se tem ID, estamos editando
            await updateTask(taskId, title);
        } else {
            // Se não tem ID, estamos criando
            await createTask(title);
        }

        taskForm.reset();
        resetFormState();
        fetchTasks();
    });

    cancelEditBtn.addEventListener('click', () => {
        taskForm.reset();
        resetFormState();
    });
}

// Buscar todas as tarefas (Read)
async function fetchTasks() {
    try {
        const response = await fetch(`${API_BASE_URL}/tasks`, {
            method: 'GET',
            headers: { 'Authorization': `Bearer ${token}` }
        });
        const tasks = await response.json();
        renderTasks(tasks);
    } catch (error) {
        console.error('Erro ao buscar tarefas:', error);
    }
}

// Renderizar tarefas na tela
function renderTasks(tasks) {
    const taskList = document.getElementById('taskList');
    taskList.innerHTML = '';

    tasks.forEach(task => {
        const li = document.createElement('li');
        li.className = 'task-item';
        li.innerHTML = `
            <span>${task.title}</span>
            <div class="task-actions">
                <button class="btn-secondary" onclick="prepareEdit('${task.id}', '${task.title}')">Editar</button>
                <button class="btn-danger" onclick="deleteTask('${task.id}')">Excluir</button>
            </div>
        `;
        taskList.appendChild(li);
    });
}

// Criar nova tarefa (Create)
async function createTask(title) {
    try {
        await fetch(`${API_BASE_URL}/tasks`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify({ title })
        });
    } catch (error) {
        console.error('Erro ao criar tarefa:', error);
    }
}

// Preparar formulário para edição
function prepareEdit(id, title) {
    document.getElementById('taskId').value = id;
    document.getElementById('taskTitle').value = title;
    document.getElementById('formTitle').innerText = 'Editar Tarefa';
    document.getElementById('taskSubmitBtn').innerText = 'Salvar';
    document.getElementById('cancelEditBtn').classList.remove('hidden');
}

// Atualizar tarefa (Update)
async function updateTask(id, title) {
    try {
        await fetch(`${API_BASE_URL}/tasks/${id}`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify({ title })
        });
    } catch (error) {
        console.error('Erro ao atualizar tarefa:', error);
    }
}

// Excluir tarefa (Delete)
async function deleteTask(id) {
    if (confirm('Tem certeza que deseja excluir esta tarefa?')) {
        try {
            await fetch(`${API_BASE_URL}/tasks/${id}`, {
                method: 'DELETE',
                headers: { 'Authorization': `Bearer ${token}` }
            });
            fetchTasks();
        } catch (error) {
            console.error('Erro ao deletar tarefa:', error);
        }
    }
}

// Resetar o estado do formulário para o padrão de criação
function resetFormState() {
    document.getElementById('taskId').value = '';
    document.getElementById('formTitle').innerText = 'Nova Tarefa';
    document.getElementById('taskSubmitBtn').innerText = 'Adicionar';
    document.getElementById('cancelEditBtn').classList.add('hidden');
}
